# Copie para .env.production e preencha ANTES de subir o compose de produção.
# docker compose -f infra/docker/docker-compose.prod.yml --env-file .env.production up -d --build

# --- domínios (DNS apontando para o servidor) ---
API_DOMAIN=api.borafest.com.br
CHECKOUT_DOMAIN=borafest.com.br
PRODUCER_DOMAIN=painel.borafest.com.br
ADMIN_DOMAIN=admin.borafest.com.br

# --- banco ---
POSTGRES_USER=borafest
POSTGRES_PASSWORD=TROQUE-ME
POSTGRES_DB=borafest
# host "postgres" = nome do serviço no compose
DATABASE_URL=postgresql://borafest:TROQUE-ME@postgres:5432/borafest?schema=public

# --- segredos ---
# gere com: openssl rand -hex 32
SESSION_JWT_SECRET=

# --- pagamentos (Pagar.me) ---
PAYMENTS_PROVIDER=pagarme
PAGARME_SECRET_KEY=
PAGARME_WEBHOOK_BASIC_USER=
PAGARME_WEBHOOK_BASIC_PASSWORD=

# --- mensageria (trocar quando os adapters reais existirem) ---
EMAIL_PROVIDER=devlog
WHATSAPP_PROVIDER=devlog

# --- taxa da plataforma (decisão 2026-07-23; overrides por org no backoffice) ---
PLATFORM_PIX_FEE_BPS=499
PLATFORM_PIX_FEE_FLOOR_CENTS=249
PLATFORM_CARD_FEE_BPS=699
