generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Identity
// ---------------------------------------------------------------------------

enum IdentityProvider {
  EMAIL
  GOOGLE
  APPLE
  PHONE
}

model User {
  id        String   @id @default(uuid()) @db.Uuid
  name      String?
  email     String?  @unique
  phone     String?  @unique
  cpf       String?  @unique
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  identities            UserIdentity[]
  otpChallenges         OtpChallenge[]
  organizationMemberships OrganizationMember[]
  reservations          Reservation[]
  orders                Order[]

  @@map("users")
}

model UserIdentity {
  id         String           @id @default(uuid()) @db.Uuid
  userId     String           @map("user_id") @db.Uuid
  provider   IdentityProvider
  providerId String           @map("provider_id")
  createdAt  DateTime         @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerId])
  @@index([userId])
  @@map("user_identities")
}

enum OtpChannel {
  EMAIL
  SMS
  WHATSAPP
}

model OtpChallenge {
  id          String     @id @default(uuid()) @db.Uuid
  userId      String?    @map("user_id") @db.Uuid
  destination String
  channel     OtpChannel
  codeHash    String     @map("code_hash")
  attempts    Int        @default(0)
  consumedAt  DateTime?  @map("consumed_at")
  expiresAt   DateTime   @map("expires_at")
  createdAt   DateTime   @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([destination])
  @@map("otp_challenges")
}

// ---------------------------------------------------------------------------
// Organizations & RBAC
// ---------------------------------------------------------------------------

enum OrganizationKind {
  INDIVIDUAL
  COMPANY
}

enum OrganizationStatus {
  PENDING_VERIFICATION
  ACTIVE
  SUSPENDED
  BLOCKED
}

model Organization {
  id        String             @id @default(uuid()) @db.Uuid
  name      String
  slug      String             @unique
  kind      OrganizationKind
  document  String             @unique
  status    OrganizationStatus @default(PENDING_VERIFICATION)
  createdAt DateTime           @default(now()) @map("created_at")
  updatedAt DateTime           @updatedAt @map("updated_at")

  members       OrganizationMember[]
  verifications OrganizerVerification[]
  bankAccounts  BankAccount[]
  venues        Venue[]
  events        Event[]

  @@map("organizations")
}

model Role {
  id          String   @id @default(uuid()) @db.Uuid
  key         String   @unique
  name        String
  description String?
  createdAt   DateTime @default(now()) @map("created_at")

  permissions RolePermission[]
  members     OrganizationMember[]

  @@map("roles")
}

model Permission {
  id          String   @id @default(uuid()) @db.Uuid
  key         String   @unique
  description String?
  createdAt   DateTime @default(now()) @map("created_at")

  roles RolePermission[]

  @@map("permissions")
}

model RolePermission {
  roleId       String @map("role_id") @db.Uuid
  permissionId String @map("permission_id") @db.Uuid

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

enum OrganizationMemberStatus {
  INVITED
  ACTIVE
  REMOVED
}

model OrganizationMember {
  id             String                   @id @default(uuid()) @db.Uuid
  organizationId String                   @map("organization_id") @db.Uuid
  userId         String                   @map("user_id") @db.Uuid
  roleId         String                   @map("role_id") @db.Uuid
  status         OrganizationMemberStatus @default(INVITED)
  invitedAt      DateTime                 @default(now()) @map("invited_at")
  joinedAt       DateTime?                @map("joined_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  role         Role         @relation(fields: [roleId], references: [id])

  @@unique([organizationId, userId])
  @@index([userId])
  @@map("organization_members")
}

enum VerificationStatus {
  PENDING
  APPROVED
  REJECTED
}

model OrganizerVerification {
  id             String              @id @default(uuid()) @db.Uuid
  organizationId String              @map("organization_id") @db.Uuid
  status         VerificationStatus  @default(PENDING)
  provider       String
  providerRef    String?             @map("provider_ref")
  reviewedBy     String?             @map("reviewed_by") @db.Uuid
  reviewedAt     DateTime?           @map("reviewed_at")
  notes          String?
  createdAt      DateTime            @default(now()) @map("created_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@map("organizer_verifications")
}

model BankAccount {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  holderName     String   @map("holder_name")
  holderDocument String   @map("holder_document")
  bankCode       String   @map("bank_code")
  agency         String
  account        String
  accountType    String   @map("account_type")
  pixKey         String?  @map("pix_key")
  isDefault      Boolean  @default(false) @map("is_default")
  createdAt      DateTime @default(now()) @map("created_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@map("bank_accounts")
}

// ---------------------------------------------------------------------------
// Events & Catalog
// ---------------------------------------------------------------------------

model Venue {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  name           String
  address        String
  city           String
  state          String
  createdAt      DateTime @default(now()) @map("created_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  events       Event[]

  @@index([organizationId])
  @@map("venues")
}

enum EventStatus {
  DRAFT
  PUBLISHED
  SALES_PAUSED
  SALES_CLOSED
  COMPLETED
  CANCELED
}

model Event {
  id             String      @id @default(uuid()) @db.Uuid
  organizationId String      @map("organization_id") @db.Uuid
  venueId        String?     @map("venue_id") @db.Uuid
  title          String
  slug           String      @unique
  description    String?
  bannerUrl      String?     @map("banner_url")
  status         EventStatus @default(DRAFT)
  startsAt       DateTime    @map("starts_at")
  endsAt         DateTime    @map("ends_at")
  timezone       String      @default("America/Sao_Paulo")
  publishedAt    DateTime?   @map("published_at")
  canceledAt     DateTime?   @map("canceled_at")
  createdAt      DateTime    @default(now()) @map("created_at")
  updatedAt      DateTime    @updatedAt @map("updated_at")

  organization Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  venue        Venue?       @relation(fields: [venueId], references: [id])
  ticketTypes  TicketType[]
  reservations Reservation[]
  orders       Order[]
  tickets      Ticket[]
  signingKey   EventSigningKey?

  @@index([organizationId])
  @@index([status])
  @@map("events")
}

model TicketType {
  id          String   @id @default(uuid()) @db.Uuid
  eventId     String   @map("event_id") @db.Uuid
  name        String
  description String?
  position    Int      @default(0)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  event Event      @relation(fields: [eventId], references: [id], onDelete: Cascade)
  lots  TicketLot[]

  @@index([eventId])
  @@map("ticket_types")
}

enum LotStatus {
  DRAFT
  SCHEDULED
  ACTIVE
  SOLD_OUT
  CLOSED
}

model TicketLot {
  id             String    @id @default(uuid()) @db.Uuid
  ticketTypeId   String    @map("ticket_type_id") @db.Uuid
  name           String
  priceCents     Int       @map("price_cents")
  feeCents       Int       @default(0) @map("fee_cents")
  capacity       Int
  soldCount      Int       @default(0) @map("sold_count")
  reservedCount  Int       @default(0) @map("reserved_count")
  maxPerOrder    Int       @default(6) @map("max_per_order")
  status         LotStatus @default(DRAFT)
  startsAt       DateTime? @map("starts_at")
  endsAt         DateTime? @map("ends_at")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  ticketType       TicketType        @relation(fields: [ticketTypeId], references: [id], onDelete: Cascade)
  reservationItems ReservationItem[]
  orderItems       OrderItem[]
  tickets          Ticket[]

  @@index([ticketTypeId])
  @@index([status])
  @@map("ticket_lots")
}

// ---------------------------------------------------------------------------
// Reservas e pedidos (venda)
// ---------------------------------------------------------------------------

enum ReservationStatus {
  ACTIVE
  CONVERTED
  EXPIRED
  CANCELED
}

model Reservation {
  id        String            @id @default(uuid()) @db.Uuid
  eventId   String            @map("event_id") @db.Uuid
  userId    String?           @map("user_id") @db.Uuid
  status    ReservationStatus @default(ACTIVE)
  expiresAt DateTime          @map("expires_at")
  createdAt DateTime          @default(now()) @map("created_at")
  updatedAt DateTime          @updatedAt @map("updated_at")

  event Event              @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user  User?              @relation(fields: [userId], references: [id], onDelete: SetNull)
  items ReservationItem[]
  order Order?

  @@index([status, expiresAt])
  @@index([eventId])
  @@map("reservations")
}

model ReservationItem {
  id            String @id @default(uuid()) @db.Uuid
  reservationId String @map("reservation_id") @db.Uuid
  ticketLotId   String @map("ticket_lot_id") @db.Uuid
  quantity      Int
  priceCents    Int    @map("price_cents")
  feeCents      Int    @map("fee_cents")

  reservation Reservation @relation(fields: [reservationId], references: [id], onDelete: Cascade)
  ticketLot   TicketLot   @relation(fields: [ticketLotId], references: [id])

  @@index([reservationId])
  @@map("reservation_items")
}

enum OrderStatus {
  CREATED
  PAYMENT_PENDING
  PAID
  FULFILLED
  EXPIRED
  CANCELED
  REFUND_PENDING
  PARTIALLY_REFUNDED
  REFUNDED
  CHARGEBACK
}

model Order {
  id            String      @id @default(uuid()) @db.Uuid
  publicToken   String      @unique @default(uuid()) @map("public_token")
  eventId       String      @map("event_id") @db.Uuid
  reservationId String      @unique @map("reservation_id") @db.Uuid
  userId        String?     @map("user_id") @db.Uuid
  contactEmail  String      @map("contact_email")
  contactName   String?     @map("contact_name")
  contactPhone  String?     @map("contact_phone")
  status        OrderStatus @default(CREATED)
  totalCents    Int         @map("total_cents")
  expiresAt     DateTime?   @map("expires_at")
  paidAt        DateTime?   @map("paid_at")
  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @updatedAt @map("updated_at")

  event       Event        @relation(fields: [eventId], references: [id])
  reservation Reservation  @relation(fields: [reservationId], references: [id])
  user        User?        @relation(fields: [userId], references: [id], onDelete: SetNull)
  items       OrderItem[]
  payments    Payment[]
  tickets     Ticket[]

  @@index([eventId])
  @@index([status])
  @@index([status, expiresAt])
  @@map("orders")
}

model OrderItem {
  id          String @id @default(uuid()) @db.Uuid
  orderId     String @map("order_id") @db.Uuid
  ticketLotId String @map("ticket_lot_id") @db.Uuid
  quantity    Int
  priceCents  Int    @map("price_cents")
  feeCents    Int    @map("fee_cents")

  order     Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  ticketLot TicketLot @relation(fields: [ticketLotId], references: [id])
  tickets   Ticket[]

  @@index([orderId])
  @@map("order_items")
}

// ---------------------------------------------------------------------------
// Pagamentos (Fase 4)
// ---------------------------------------------------------------------------

enum PaymentMethod {
  PIX
  CARD
}

enum PaymentStatus {
  PENDING
  AUTHORIZED
  PAID
  FAILED
  CANCELED
  EXPIRED
  REFUND_PENDING
  REFUNDED
  CHARGEBACK
}

model Payment {
  id             String        @id @default(uuid()) @db.Uuid
  orderId        String        @map("order_id") @db.Uuid
  provider       String
  method         PaymentMethod
  status         PaymentStatus @default(PENDING)
  amountCents    Int           @map("amount_cents")
  externalId     String?       @map("external_id")
  idempotencyKey String?       @unique @map("idempotency_key")
  pixQrCodeText  String?       @map("pix_qr_code_text")
  installments   Int?
  failReason     String?       @map("fail_reason")
  expiresAt      DateTime?     @map("expires_at")
  paidAt         DateTime?     @map("paid_at")
  metadata       Json?
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")

  order  Order          @relation(fields: [orderId], references: [id])
  events PaymentEvent[]

  @@unique([provider, externalId])
  @@index([orderId])
  @@index([status, expiresAt])
  @@map("payments")
}

/// Evento de pagamento recebido do gateway (via webhook ou reconciliação).
/// unique(provider, externalEventId) garante processamento idempotente.
model PaymentEvent {
  id              String    @id @default(uuid()) @db.Uuid
  paymentId       String    @map("payment_id") @db.Uuid
  provider        String
  externalEventId String    @map("external_event_id")
  type            String
  payload         Json
  processedAt     DateTime? @map("processed_at")
  createdAt       DateTime  @default(now()) @map("created_at")

  payment Payment @relation(fields: [paymentId], references: [id], onDelete: Cascade)

  @@unique([provider, externalEventId])
  @@index([paymentId])
  @@map("payment_events")
}

enum WebhookDeliveryStatus {
  RECEIVED
  PROCESSED
  IGNORED
  FAILED
}

/// Toda entrega de webhook é registrada com o payload bruto, mesmo quando
/// rejeitada, para auditoria e reprocessamento.
model WebhookDelivery {
  id              String                @id @default(uuid()) @db.Uuid
  provider        String
  eventType       String?               @map("event_type")
  externalEventId String?               @map("external_event_id")
  signatureValid  Boolean               @map("signature_valid")
  status          WebhookDeliveryStatus @default(RECEIVED)
  error           String?
  rawBody         String                @map("raw_body")
  headers         Json
  receivedAt      DateTime              @default(now()) @map("received_at")
  processedAt     DateTime?             @map("processed_at")

  @@index([provider, receivedAt])
  @@map("webhook_deliveries")
}

// ---------------------------------------------------------------------------
// Ingressos (Fase 4 — emissão)
// ---------------------------------------------------------------------------

enum TicketStatus {
  ISSUED
  ACTIVE
  CHECKED_IN
  TRANSFERRED
  CANCELED
  REFUNDED
}

model Ticket {
  id            String       @id @default(uuid()) @db.Uuid
  orderId       String       @map("order_id") @db.Uuid
  orderItemId   String       @map("order_item_id") @db.Uuid
  eventId       String       @map("event_id") @db.Uuid
  ticketLotId   String       @map("ticket_lot_id") @db.Uuid
  seq           Int
  code          String       @unique
  qrToken       String       @map("qr_token")
  status        TicketStatus @default(ISSUED)
  attendeeName  String?      @map("attendee_name")
  attendeeEmail String?      @map("attendee_email")
  issuedAt      DateTime     @default(now()) @map("issued_at")
  checkedInAt   DateTime?    @map("checked_in_at")
  canceledAt    DateTime?    @map("canceled_at")

  order     Order     @relation(fields: [orderId], references: [id])
  orderItem OrderItem @relation(fields: [orderItemId], references: [id])
  event     Event     @relation(fields: [eventId], references: [id])
  ticketLot TicketLot @relation(fields: [ticketLotId], references: [id])

  @@unique([orderItemId, seq])
  @@index([eventId, status])
  @@index([orderId])
  @@map("tickets")
}

// ---------------------------------------------------------------------------
// Notificações (Fase 5 — entrega de ingressos e avisos)
// ---------------------------------------------------------------------------

enum NotificationChannel {
  EMAIL
  WHATSAPP
}

enum NotificationStatus {
  PENDING
  SENT
  FAILED
}

/// Fila persistente de notificações: linhas PENDING são processadas pelo
/// worker de entrega (retry com backoff; nunca perde mensagem por queda de fila).
model Notification {
  id          String              @id @default(uuid()) @db.Uuid
  channel     NotificationChannel
  recipient   String
  template    String
  payload     Json
  status      NotificationStatus  @default(PENDING)
  attempts    Int                 @default(0)
  error       String?
  availableAt DateTime            @default(now()) @map("available_at")
  sentAt      DateTime?           @map("sent_at")
  orderId     String?             @map("order_id") @db.Uuid
  createdAt   DateTime            @default(now()) @map("created_at")

  @@index([status, availableAt])
  @@index([orderId])
  @@map("notifications")
}

/// Par de chaves Ed25519 por evento para assinar o QR dos ingressos.
/// A chave pública vai no manifesto dos validadores (Fase 7).
/// TODO produção: mover a chave privada para KMS/secret manager.
model EventSigningKey {
  id            String   @id @default(uuid()) @db.Uuid
  eventId       String   @unique @map("event_id") @db.Uuid
  algorithm     String   @default("ed25519")
  publicKeyPem  String   @map("public_key_pem")
  privateKeyPem String   @map("private_key_pem")
  createdAt     DateTime @default(now()) @map("created_at")

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@map("event_signing_keys")
}

// ---------------------------------------------------------------------------
// Cross-cutting infra: outbox, idempotency, audit
// ---------------------------------------------------------------------------

enum OutboxStatus {
  PENDING
  PROCESSING
  PROCESSED
  FAILED
}

model OutboxEvent {
  id          String       @id @default(uuid()) @db.Uuid
  aggregateType String     @map("aggregate_type")
  aggregateId String       @map("aggregate_id")
  eventType   String       @map("event_type")
  payload     Json
  status      OutboxStatus @default(PENDING)
  attempts    Int          @default(0)
  availableAt DateTime     @default(now()) @map("available_at")
  processedAt DateTime?    @map("processed_at")
  createdAt   DateTime     @default(now()) @map("created_at")

  @@index([status, availableAt])
  @@map("outbox_events")
}

model IdempotencyKey {
  key          String    @id
  scope        String
  requestHash  String    @map("request_hash")
  responseBody Json?     @map("response_body")
  statusCode   Int?      @map("status_code")
  lockedAt     DateTime? @map("locked_at")
  completedAt  DateTime? @map("completed_at")
  createdAt    DateTime  @default(now()) @map("created_at")

  @@index([scope])
  @@map("idempotency_keys")
}

model AuditLog {
  id           String   @id @default(uuid()) @db.Uuid
  actorUserId  String?  @map("actor_user_id") @db.Uuid
  organizationId String? @map("organization_id") @db.Uuid
  action       String
  entityType   String   @map("entity_type")
  entityId     String   @map("entity_id")
  metadata     Json?
  createdAt    DateTime @default(now()) @map("created_at")

  @@index([organizationId, createdAt])
  @@index([entityType, entityId])
  @@map("audit_logs")
}
