DATABASE_URL="postgresql://borafest:borafest@localhost:5443/borafest?schema=public"
REDIS_URL="redis://localhost:6380"
NODE_ENV=development
API_PORT=3333
SESSION_JWT_SECRET=
PAYMENTS_PROVIDER=mock
MOCK_WEBHOOK_SECRET=mock-webhook-secret-dev

# Pagar.me (gateway primário — usar PAYMENTS_PROVIDER=pagarme em homolog/prod)
PAGARME_SECRET_KEY=
PAGARME_WEBHOOK_SECRET=
PAGARME_WEBHOOK_BASIC_USER=
PAGARME_WEBHOOK_BASIC_PASSWORD=
# PAGARME_API_URL=https://api.pagar.me/core/v5
# Chave PÚBLICA (pk_) — vai no app mobile (EXPO_PUBLIC_PAGARME_PUBLIC_KEY),
# nunca no backend. Sem ela, o app de comprador tokeniza cartão em modo mock.

# Notificações (Fase 5)
WEB_BASE_URL=http://localhost:3000
EMAIL_PROVIDER=devlog
WHATSAPP_PROVIDER=devlog
# PUSH_PROVIDER=expo é o default (Expo Push API é grátis, não precisa de conta) — devlog só se quiser desligar.
# EXPO_ACCESS_TOKEN= (opcional, evita rate-limit em volume alto)
